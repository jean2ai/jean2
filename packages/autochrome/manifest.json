{
  "manifest_version": 3,
  "name": "Jean2 Autochrome",
  "description": "Jean2 browser automation extension - enables AI to read, navigate, and interact with web pages",
  "version": "0.2.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {},
  "action": {
    "default_title": "Jean2 Autochrome",
    "default_popup": "popup.html"
  }
}
