{
  "name": "@jean2/server",
  "version": "0.9.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "jean2": "./dist/bin/jean2"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "auth:token": "bun run src/auth/cli.ts show",
    "auth:regenerate": "bun run src/auth/cli.ts regenerate",
    "auth:path": "bun run src/auth/cli.ts path",
    "build:bin": "VERSION=$(cat VERSION) && bun build --compile --define=JEAN2_VERSION=\"'${VERSION}'\" --outfile=dist/bin/jean2 src/cli.ts",
    "build:bin:macos": "VERSION=$(cat VERSION) && bun build --compile --define=JEAN2_VERSION=\"'${VERSION}'\" --outfile=dist/bin/jean2-macos-arm64 src/cli.ts",
    "build:bin:linux": "VERSION=$(cat VERSION) && bun build --compile --define=JEAN2_VERSION=\"'${VERSION}'\" --outfile=dist/bin/jean2-linux-x64 src/cli.ts",
    "build:bin:windows": "VERSION=$(cat VERSION) && bun build --compile --define=JEAN2_VERSION=\"'${VERSION}'\" --outfile=dist/bin/jean2-windows-x64.exe src/cli.ts",
    "build:all": "bun run build && bun run build:bin"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@clack/prompts": "^0.10.0",
    "@jean2/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.116",
    "bun-pty": "^0.4.8",
    "cross-spawn": "^7.0.6",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.8",
    "vercel-minimax-ai-provider": "^0.0.2",
    "zhipu-ai-provider": "^0.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.19.15",
    "bun-types": "^1.3.9",
    "typescript": "^5.7.2"
  }
}
