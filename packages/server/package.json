{
  "name": "@jean2/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "auth:token": "bun run src/auth/cli.ts show",
    "auth:regenerate": "bun run src/auth/cli.ts regenerate",
    "auth:path": "bun run src/auth/cli.ts path"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@jean2/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.0",
    "fast-glob": "^3.3.2",
    "hono": "^4.0.0",
    "vercel-minimax-ai-provider": "^0.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^22.10.1",
    "bun-types": "^1.3.9",
    "typescript": "^5.7.2"
  }
}
