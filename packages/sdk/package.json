{
  "name": "@jean2/sdk",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && bun scripts/add-js-extensions.ts",
    "typecheck": "tsc --noEmit",
    "version:sync": "echo \"export const version: string = '$npm_package_version';\" > src/version.ts"
  }
}
