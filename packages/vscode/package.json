{
  "name": "jean2code",
  "displayName": "Jean2Code",
  "description": "AI coding assistant for VS Code — chat with your codebase using Jean2",
  "version": "0.1.0",
  "publisher": "jean2",
  "icon": "client-dist/icon-192.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/jean2/jean2",
    "directory": "packages/vscode"
  },
  "categories": ["Chat", "AI"],
  "keywords": ["ai", "chat", "assistant", "coding", "agent", "llm"],
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/jean2/jean2/issues"
  },
  "homepage": "https://github.com/jean2/jean2/tree/main/packages/vscode",
  "galleryBanner": {
    "color": "#1a1b1e",
    "theme": "dark"
  },
  "pricing": "Free",
  "contributes": {
    "commands": [
      {
        "command": "jean2.openChat",
        "title": "Jean2: Open Chat"
      }
    ],
    "menus": {},
    "configuration": {
      "title": "Jean2",
      "properties": {
        "jean2.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the Jean2 server"
        },
        "jean2.token": {
          "type": "string",
          "default": "",
          "description": "Authentication token for the Jean2 server"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "package": "bun run build && bunx vsce package --no-dependencies",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.7.2"
  }
}
