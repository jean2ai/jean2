{
  "name": "@jean2/client",
  "version": "0.8.4",
  "private": false,
  "type": "module",
  "bin": {
    "j2": "./dist/cli.mjs"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsr generate && tsc && vite build",
    "build:npx": "bun run build && esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.mjs --external:open --banner:js='#!/usr/bin/env node'",
    "prepublishOnly": "bun run build:npx",
    "routes:generate": "tsr generate",
    "typecheck": "tsr generate && tsc --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev --port 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@jean2/sdk": "workspace:*",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-virtual": "^3.13.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "open": "^10.1.0",
    "prism-react-renderer": "^2.4.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-cli": "^1.166.33",
    "@tanstack/router-plugin": "^1.167.18",
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.25.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0"
  }
}
