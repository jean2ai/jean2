{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Jean2",
  "version": "0.1.0",
  "identifier": "com.jean2.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Jean2",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "minWidth": 500,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Jean2 AI Agent",
    "longDescription": "Jean2 - AI Agent Desktop and Mobile Application",
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "resources": {
      "../src/assets/sounds/*": "sounds/"
    }
  }
}
