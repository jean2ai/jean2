{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true,
    "types": ["vitest/globals"],
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["../src/**/*", "./**/*"]
}
