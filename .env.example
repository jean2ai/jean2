# =============================================================================
# Server Configuration
# =============================================================================
JEAN2_PORT=3000
JEAN2_HOST=0.0.0.0

# =============================================================================
# Authentication
# =============================================================================
# Set to 'true' to disable authentication (default: false)
# JEAN2_DISABLE_AUTH=false

# =============================================================================
# Database
# =============================================================================
JEAN2_DATABASE_PATH=./data/agent.db

# =============================================================================
# Paths (optional - defaults shown)
# =============================================================================
# JEAN2_PRECONFIGS_PATH=~/.jean2/preconfigs
# JEAN2_TOOLS_PATH=./packages/server/data/tools

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# Set only the API key(s) for the provider(s) you want to use
# JEAN2_LLM_OPENAI_API_KEY=your-openai-api-key-here
# JEAN2_LLM_ANTHROPIC_API_KEY=your-anthropic-api-key-here
# JEAN2_LLM_OPENROUTER_API_KEY=your-openrouter-api-key-here
# JEAN2_LLM_GOOGLE_API_KEY=your-google-api-key-here
# JEAN2_LLM_MINIMAX_API_KEY=your-minimax-api-key-here

# =============================================================================
# LLM Settings
# =============================================================================
# JEAN2_LLM_BASE_URL=https://openrouter.ai/api/v1
JEAN2_LLM_MAX_TOKENS=4096
JEAN2_LLM_TEMPERATURE=0.7

# =============================================================================
# Tools Configuration
# =============================================================================
# TODOS_DB_PATH=./data/todos.db
# LSP_SERVER_URL=http://localhost
# LSP_SERVER_PORT=3001

# =============================================================================
# TLS (optional - for HTTPS/WSS during development)
# =============================================================================
# JEAN2_TLS_ENABLED=false
# JEAN2_TLS_CERT_FILE=
# JEAN2_TLS_KEY_FILE=
