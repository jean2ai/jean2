{
  "name": "jean2",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Jean2 - AI Agent Monorepo",
  "workspaces": [
    "packages/*",
    "tools"
  ],
  "scripts": {
    "dev": "bun run dev:server & bun run dev:client",
    "dev:https": "bun run dev:server & bun run dev:client:https",
    "dev:be": "bun run dev:server",
    "dev:server": "cd packages/server && bun --watch --env-file=../../.env src/index.ts",
    "dev:client": "cd packages/client && bun run dev",
    "dev:client:https": "cd packages/client && bun --env-file=../../.env run dev",
    "preview": "cd packages/client && bun run build && bun run preview",
    "preview:client:https": "cd packages/client && bun run build && bun --env-file=../../.env run preview",
    "preview:server:https": "cd packages/server && bun --env-file=../../.env src/index.ts",
    "preview:https": "bun run preview:server:https & bun run preview:client:https",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:bin": "cd packages/server && bun run build:bin",
    "build:bin:macos": "cd packages/server && bun run build:bin:macos",
    "build:bin:linux": "cd packages/server && bun run build:bin:linux",
    "build:bin:windows": "cd packages/server && bun run build:bin:windows",
    "build:all": "cd packages/server && bun run build:all",
    "build:tools": "bun run tools/build.ts",

    "dev:electron": "cd packages/client-electron && bun run electron:dev",
    "electron:build": "cd packages/client-electron && bun run electron:build",
    "electron:build:mac:local": "cd packages/client-electron && bun run electron:build:mac:local",
    "electron:build:mac:release": "cd packages/client-electron && bun run electron:build:mac:release",
    "electron:build:win": "cd packages/client-electron && bun run electron:build:win",
    "test:client": "cd packages/client && bun vitest run",
    "test:server": "bun test packages/server",
    "test:server:coverage": "cd packages/server && bun test --coverage",
    "test:tools": "bun test tools",
    "test": "bun test packages/server packages/sdk tools && bun run test:client",
    "sandbox": "bun packages/sandbox-cli/src/cli.ts",
    "build:vscode": "cd packages/vscode && bash scripts/build.sh",
    "package:vscode": "cd packages/vscode && bun run package",
    "typecheck:vscode": "cd packages/vscode && bun run typecheck",
    "test:vscode": "cd packages/vscode && bun test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^8.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "diff": "^8.0.3"
  }
}
